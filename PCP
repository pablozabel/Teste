//À embarcar
FINALIZADO:
NoConcatenate
Load 
    VGBEL as [Número do Pedido],
    VBELN as [Número da remessa],
	ApplyMap('Map_Requisicao',VGBEL, null()) as [Número da requisição],
    WERKS as [CD ORIGEM],
	LFIMG as QTD,
    LFIMG as QTD_FINALIZADO,
    MATNR as %MATERIAL_CHAVE,
    'À EMBARCAR' as TIPO
FROM [lib://CNNDIR-Dados/Extraídos/SAP ECC/LOG-LEADTIME/LIPS.qvd] (qvd)
Where Exists(filtro_buffer, VGBEL) and match(PSTYV ,'YFDP','YSDP');

NoConcatenate
LTAK:
Load
	text(VBELN) as [Número da remessa],
    BDATU as [%DATA_CHAVE],
    TANUM
FROM [lib://CNNDIR-DadosDEV/Temporários/Pablo_Projjetta/Extraidos/LTAK.qvd](qvd);

Inner join (LTAK)
Load
	TANUM
from [lib://CNNDIR-DadosDEV/Temporários/Pablo_Projjetta/Extraidos/LTAP.qvd](qvd)
where NISTM >0;

left join (FINALIZADO)
Load Distinct
	[Número da remessa],
	date(max([%DATA_CHAVE])) as [%DATA_CHAVE]
resident LTAK
group by [Número da remessa];
drop table LTAK;

Inner join (FINALIZADO)
Load
	text(VBELN) as [Número da remessa]
from [lib://CNNDIR-Dados/Extraídos/SAP ECC/VBUK.qvd](qvd)
where match(trim(LVSTK), 'C');

Concatenate (TMP_FATO)
Load 
	[Número da requisição],
	[Número do Pedido],
    [Número da remessa],
    [Número da remessa] as [Remessa Finalizada],
    %MATERIAL_CHAVE,
    QTD_FINALIZADO,
	QTD,
    [CD ORIGEM],
    TIPO,
    [%DATA_CHAVE] as DAT_FINALIZADO,
    [%DATA_CHAVE]
resident FINALIZADO
where not Exists(VBELN_FILTRO, [Número da remessa]);

NoConcatenate
EMBARCADO:
// Concatenate (TMP_FATO)
Load 
	[Número da requisição],
	[Número do Pedido],
    [Número da remessa],
    [Número da remessa] as [Remessa Embarcada],
    %MATERIAL_CHAVE,
    QTD as QTD_EMBARCADO,
	QTD,
    [CD ORIGEM],
    [%DATA_CHAVE] as DAT_FINALIZADO,
    'EMBARCADO' as TIPO
resident FINALIZADO
where Exists(VBELN_FILTRO, [Número da remessa]);

drop table FINALIZADO;

inner join (EMBARCADO)
Load 
	VBELN_FILTRO as [Número da remessa],
    min(ERDAT) as %DATA_CHAVE,
    date(min(ERDAT)) as DAT_EMBARCADO
resident Embarcadas
group by VBELN_FILTRO;

Concatenate (TMP_FATO)
Load *
resident EMBARCADO;
drop table EMBARCADO;

//Produção

PROD:
NoConcatenate
Load 
    VGBEL as [Número do Pedido],
    VBELN as [Número da remessa],
    ApplyMap('Map_Requisicao',VGBEL, null()) as [Número da requisição],
    LFIMG as QTD_PRODUCAO,
	LFIMG as QTD,
    MATNR as %MATERIAL_CHAVE,
    WERKS as [CD ORIGEM],
    date(ERDAT,'DD/MM/YYYY') as [%DATA_CHAVE],
    date(ERDAT) as DAT_PRODUCAO,
    'PRODUÇÃO' as TIPO
FROM [lib://CNNDIR-Dados/Extraídos/SAP ECC/LOG-LEADTIME/LIPS.qvd] (qvd)
Where Exists(filtro_buffer, VGBEL) and match(PSTYV,'YFDP','YSDP') and not Exists([Remessa Finalizada], VBELN) and not Exists([Remessa Embarcada], VBELN);

Inner join (PROD)
Load
	text(VBELN) as [Número da remessa]
from [lib://CNNDIR-Dados/Extraídos/SAP ECC/VBUK.qvd](qvd)
where not match(trim(LVSTK), 'C',''); //LVSTA

Concatenate (TMP_FATO)
Load 
	[Número da requisição],
	[Número do Pedido],
    [Número da remessa],
    [Número da remessa] as [Remessa Produção],
    %MATERIAL_CHAVE,
	QTD,
    QTD_PRODUCAO,
    [CD ORIGEM],
    TIPO,
    DAT_PRODUCAO,
    [%DATA_CHAVE]
resident PROD;

drop table PROD;

//REQUISIÇÕES

Concatenate(TMP_FATO)
Load 
    LOEKZ,
//     BSART,
   	MENGE as QTD_SOLICITADA,
   	MENGE as QTD,
//     WERKS as [%CENTRO_CHAVE],
    RESWK as [CD ORIGEM],
    MATNR as %MATERIAL_CHAVE,
    'REQUISIÇÃO' as TIPO,
    date(CREATIONDATE,'DD/MM/YYYY') as [%DATA_CHAVE],
	date(CREATIONDATE) as DAT_CRIACAO,
    VBELN as [Número da remessa],
    BANFN as [Número da requisição],
    EBELN as [Número do Pedido],
