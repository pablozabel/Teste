	or (TPPROCESSO = 'BF' and CDORIGEM = '1075' and Match(WERKS, '6000','7000')) or (TPPROCESSO = 'BF' and CDORIGEM = '1156' and Match(WERKS, '6000','8000'))
	or (TPPROCESSO = 'PP' and CDORIGEM = '1075' and Match(WERKS, '1156','1117')) or (TPPROCESSO = 'PP' and CDORIGEM = '1156' and Match(WERKS, '1075','1117'));

Concatenate (ZWMUCT006)
load 
	EXIDV,
	EBELN,
    CDSECUNDARIO as [CD ORIGEM],
    VBELN_2 as VBELN,
    null() as VBELN_1,
    VBELN_2,
    null() as VBELN_3,
	DTENT_2 as %DATA_CHAVE,
    VBELN_2_DT as DAT_CRIACAO_REMESSA,
    WERKS as %CENTRO_CHAVE_CROSS
from [$(vGlobalDirDadoExtraidoSAPECC)/Períodos/ZWMUCT006_ATUAL.qvd] (qvd)
where TPPROCESSO = 'CK' and trim(CDSECUNDARIO) <> '';

Concatenate (ZWMUCT006)
load 
	EXIDV,
	EBELN,
    CDHUB as [CD ORIGEM],
    VBELN_3 as VBELN,
    null() as VBELN_1,
    null() as VBELN_2,
    VBELN_3,
	DTENT_3 as %DATA_CHAVE,
    VBELN_3_DT as DAT_CRIACAO_REMESSA,
    WERKS as %CENTRO_CHAVE_CROSS
from [$(vGlobalDirDadoExtraidoSAPECC)/Períodos/ZWMUCT006_ATUAL.qvd] (qvd)
where TPPROCESSO = 'CK' and CDHUB = '1117';

