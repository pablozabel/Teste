Load 
	*,
    [%DATA_CHAVE]						as DAT_PRODUCAO,
	QTD                    				as QTD_PRODUCAO,
    'PP' 								as AUX,
    'PRODUÇÃO' 							as TIPO
resident REMESSAS_PP
