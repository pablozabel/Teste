Datas_validas:
Load
	DAT_CALENDARIO_CIVIL
FROM [$(vGlobalDirDadoTransformado)\Dim_Calendario_Comercial.qvd] (qvd)
where DAT_CALENDARIO_CIVIL >= date(AddMonths(today(),-2)) and DAT_CALENDARIO_CIVIL <= today();

//Controle de remessas já embarcadas
tmp_Embarcadas:
LOAD 
	COD_REMESSA as VBELN_FILTRO,
	DAT_EMBARQUE_CARGA //as ERDAT
from [lib://CNNDIR-Dados/Transformados/LOG-LEADTIME/FATO_REMESSAS.qvd](qvd)
Where Exists(DAT_CALENDARIO_CIVIL,DAT_EMBARQUE_CARGA);

concatenate(tmp_Embarcadas)
Load
	VBELV as VBELN_FILTRO,
    ERDAT as ERDAT_VBFA
from [lib://CNNDIR-Dados/Extraídos/SAP ECC/LOG-LEADTIME/VBFA.qvd](qvd)
where BWART = '861';

concatenate(tmp_Embarcadas)
Load
	VBELN as VBELN_FILTRO,
    ERDAT as ERDAT_VTTP
from [lib://CNNDIR-Dados/Extraídos/SAP ECC/LOG-LEADTIME/VTTP.qvd](qvd);

NoConcatenate
Embarcadas:
Load
	VBELN_FILTRO,
    alt(max(DAT_EMBARQUE_CARGA), min(ERDAT_VTTP), max(ERDAT_VBFA)) as ERDAT
resident tmp_Embarcadas
group by 
	VBELN_FILTRO;

MapCDAbastecedor:
Mapping load 
