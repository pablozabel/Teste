[Calendário Comercial]:
LOAD Distinct
    DAT_CALENDARIO_CIVIL								                                AS [Data de Referência],
    date(DAT_CALENDARIO_CIVIL,'DD/MMM')                  								AS [Data de Referência Resumida],
    day(DAT_CALENDARIO_CIVIL)                                                           AS [Dia do Mês],
    TIPO															                    AS [Tipo_Data],
    NUM_DIA_SEMANA                                                                      AS [Dia da Semana],
    If(DAT_CALENDARIO_CIVIL=(Today()-1) 
      or NUM_DIA_SEMANA=7,1,Null())                                                     AS [Flag Último Dia Semana],
    If(DAT_CALENDARIO_CIVIL=(Today()-1) 
      or NUM_DIA_SEMANA_GIRO=7,1,Null())                                                AS [Flag Último Dia Semana Giro],      
    NUM_SEMANA		                                                                    AS [Número da Semana],
    Dual(NUM_SEMANA&'/'&Year(DAT_CALENDARIO),
         Num(Year(DAT_CALENDARIO)&NUM_SEMANA))                                          AS [Semana/Ano],
    DAT_CALENDARIO 											                            AS [%Data Comercial],
    Year(DAT_CALENDARIO)&' - '&NUM_SEMANA&' - '&NUM_DIA_SEMANA                          AS [Ano Semana Dia],
    Year([DAT_CALENDARIO_CIVIL])                      				                    AS [Ano Civil],
    Year([DAT_CALENDARIO])					    				                	    AS [Ano Comercial],
    Month([DAT_CALENDARIO_CIVIL])			            			                    AS [Mês Civil],
    Month([DAT_CALENDARIO])					        				                    AS [Mês Comercial],
    Date([DAT_CALENDARIO_CIVIL],'MM/YYYY')							                    AS [Mês Ano Civil],
    Date([DAT_CALENDARIO],'MM/YYYY')								                    AS [Mês Ano Comercial],
    If((Num(AsOfDate)<=Num((Today()-7))) and (Num(AsOfDate)>=Num((Today()-56))),1,0) AS [Flag 8 Semanas tmp]
////MM002 - Fim  
FROM [$(vGlobalDirDadoTransformado)/Dim_Calendario_Comercial_Asof_Cubo.qvd] (qvd)
Where DAT_CALENDARIO_CIVIL >= AddMonths(Today(),-6) and DAT_CALENDARIO_CIVIL <= AddMonths(Today(),1) and TIPO = 'Dia Ano Atual';
/*Exists([Data de Referência],DAT_CALENDARIO_CIVIL)*/ 

