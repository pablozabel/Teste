**************************/
NoConcatenate
tmp_dat_embarcado:
Load
	[Número da requisição],
    date(max(DAT_EMBARCADO)) as TMP_DAT_EMBARCADO
Resident TMP_FATO
where TIPO = 'EMBARCADO'
group by 
	[Número da requisição];

left join (EBAN)
Load 
	[Número da requisição] as BANFN,
    TMP_DAT_EMBARCADO
Resident tmp_dat_embarcado;
drop table tmp_dat_embarcado;
    
Concatenate (TMP_FATO)
Load 
	*,
	QTD_TOTAL_REQUISICAO-QTD_TOTAL_EMBARCADO as QTD_NAO_ATENDIDA
    where QTD_TOTAL_REQUISICAO <> QTD_TOTAL_EMBARCADO;
Load 
   	alt(sum(MENGE),0) as QTD_TOTAL_REQUISICAO,
    RESWK as [CD ORIGEM],
    MATNR as %MATERIAL_CHAVE,
    VBELN as [Número da remessa],
    BANFN as [Número da requisição],
    EBELN as [Número do Pedido],
    ApplyMap('Map_qtd_embarcado',BANFN&'|'&MATNR,0) as QTD_TOTAL_EMBARCADO,
    date(max(TMP_DAT_EMBARCADO)) as [%DATA_CHAVE]
resident EBAN
where not IsNull(TMP_DAT_EMBARCADO)
group by
    RESWK,
    MATNR,
    VBELN,
    BANFN,
    EBELN;

left join (TMP_FATO)
Load distinct
    BANFN as [Número da requisição],
	BSART
resident EBAN;
