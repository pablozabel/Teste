EBAN:
Load
    LOEKZ,
    BSART,
    MENGE,
    WERKS,
    RESWK,
    CREATIONDATE,
    BANFN,
    EBELN,
    EBELN as filtro_buffer,
    ApplyMap('Map_Remessa',EBELN,null()) as VBELN,
	MATNR
from [lib://CNNDIR-DadosDEV/Temporários/Pablo_Projjetta/Extraidos/EBAN.qvd](qvd)
where LOEKZ <> 'X' and match(BSART,'ZBF','ZMD','ZFT','ZSKU')  AND Exists(DAT_CALENDARIO_CIVIL,CREATIONDATE);

Map_destino:
Mapping load
	BANFN,
	WERKS
resident EBAN;

Map_Requisicao:
mapping Load
    EBELN,
    BANFN
resident EBAN;

Map_producao:
mapping load
	BANFN as [Número da requisição],
    count(distinct EBELN) as NUM_PEDIDOS_REQUISICAO
resident EBAN
where trim(EBELN) <> ''
group by
	BANFN;

