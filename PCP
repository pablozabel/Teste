Dim_Material:
LOAD
    COD_MATERIAL	AS %MATERIAL_CHAVE,
    DES_MATERIAL	AS [Material - Descrição],
	num(Right(COD_MATERIAL,10)) as [Material - Código],
    COD_MATERIAL_PAI as [Material Pai - Código],
	If(Len(COD_MATERIAL_PAI)<2, DES_MATERIAL, left(DES_MATERIAL, index(DES_MATERIAL, ',') -1)) as [Material Pai - Descrição]
FROM [lib://CNNDIR-Dados/Transformados/Dim_Material.qvd](qvd);

Dim_Arvore:
LOAD
    COD_CHAVE_ARVORE                               as %ARVORE_CHAVE,
    DES_SUB_GRUPO                                  AS [Material - Subgrupo],
    DES_GRUPO                                      AS [Material - Grupo],
    DES_SUB_SEGMENTO                               AS [Material - Subsegmento],
    DES_SEGMENTO                                   AS [Material - Segmento],
    DES_DEPARTAMENTO                               AS [Material - Departamento],
    DES_ORGANIZACAO                                AS [Material - Organização],
    COD_TIPO_FAIXA_PRECO                           AS [Material - Código Faixa de Preço],
    DES_FAIXA_PRECO                                AS [Material - Faixa de Preço],
    IND_STATUS                                     AS [Material - Status],
    DES_GRUPO_COMPRADOR                            AS [Material - Grupo Comprador],
    DES_COMPRADOR                                  AS [Material - Comprador],
    DES_FAB_MIT                                    AS [FAB/MIT],
    DES_DEPARTAMENTO&' - '&DES_SEGMENTO&' - '&DES_SUB_SEGMENTO&' - '&DES_GRUPO&' - '&DES_SUB_GRUPO AS [Árvore - Descrição]
FROM [lib://CNNDIR-Dados/Transformados/Dim_Arvore_Mercadologica_Cubo.qvd] (qvd)
WHERE Exists(%ARVORE_CHAVE, COD_CHAVE_ARVORE);

