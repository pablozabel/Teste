load 
	EXIDV,
	EBELN,
    CDORIGEM as [CD ORIGEM],
    VBELN_1 as VBELN,
    VBELN_1,
    null() as VBELN_2,
    null() as VBELN_3,
	DTENT_1 as %DATA_CHAVE,
    VBELN_1_DT as DAT_CRIACAO_REMESSA,
//     WERKS as %CENTRO_CHAVE_CROSS,
    if(match(CDSECUNDARIO, '1156','1075'),
		CDSECUNDARIO,
		if(match(CDHUB, '1117'),
        	CDHUB,
			WERKS)) as  %CENTRO_CHAVE_CROSS,
