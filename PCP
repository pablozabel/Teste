NoConcatenate
FATO:
Load
	*,
    %CENTRO_CHAVE&'|'&(num(weekday([Data de Referência]))+1) as %CHAVE_CAPACIDADE_DIA
where not WildMatch(%CENTRO_CHAVE, '9???', '1119') or IsNull(%CENTRO_CHAVE) // Excluindo lojas novas e ecommerce mas mantendo requisições sem loja destino
;

Load
	*,
	if(CD_ABASTECEDOR = [CD ORIGEM],
		%CENTRO_CHAVE_TMP,
        CD_ABASTECEDOR) as %CENTRO_CHAVE,
        
    if((AGE_EMBARQUE)<=2,
		'<= 2D',
    	if((AGE_EMBARQUE)<=4,
    		'>= 3D <= 4D',
    		if((AGE_EMBARQUE) <= 7,
				'>= 5D <= 7D',
                if((AGE_EMBARQUE) > 7,
                	'> 7D'
		)))) as [Faixa Age Embarque],
        
    if((AGE_PRODUCAO)<=2,
		'<= 2D',
    	if((AGE_PRODUCAO)<=4,
    		'>= 3D <= 4D',
    		if((AGE_PRODUCAO) <= 7,
				'>= 5D <= 7D',
                if((AGE_PRODUCAO) > 7,
                	'> 7D'
		)))) as [Faixa Age Produção]
;
Load
	*,
    ApplyMap('MapCDAbastecedor',%CENTRO_CHAVE_TMP,NULL()) as CD_ABASTECEDOR,
    (today()-[Data de Referência]) as dias_referencia,
// 	Year([%DATA_CHAVE])&Week([%DATA_CHAVE], 0, 0, 0)&ApplyMap('MapPlanoProducao',ORIGEM,null())&[CD ORIGEM] as %CHAVE_PLANO_PRODUCAO,
    ApplyMap('MapPlanoProducao',ORIGEM,null()) as GRUPO_PLANO_PRODUCAO,
    DAT_EMBARCADO - DAT_FINALIZADO as AGE_EMBARQUE,
    DAT_FINALIZADO - DAT_PRODUCAO_HISTORICO as AGE_PRODUCAO
;
load 
	*,
    today() as DAT_FOTOGRAFIA,
    if(TMP_ORIGEM = 'CROSS',
    	%CENTRO_CHAVE_CROSS,
        ApplyMap('Map_destino', [Número da requisição], NULL())) as %CENTRO_CHAVE_TMP,
    alt(date([%DATA_CHAVE],'DD/MM/YYYY'),today()) as [Data de Referência],
    ApplyMap('MapArvore',%MATERIAL_CHAVE,null()) as %ARVORE_CHAVE,
    alt(ApplyMap('MAP_VOLUME_PROD',[Número da remessa], null()),0) as VOLUME_PRODUCAO,
    num(Right([Número da requisição],8)) as [Código da requisição],
    num(Right([Número da remessa],8)) as [Código da remessa],
    date(alt(ApplyMap('MAP_DATA_ENTRADA_CD',[Número da remessa]&[Número do Pedido], null()),  ApplyMap('MAP_Dat_Producao', [Número da remessa], null()))) as DAT_PRODUCAO_HISTORICO,
	if(match(BSART, 'ZBF'),
		'BUFFER',
		if(match(BSART, 'ZMD','ZFT'),
			'ACESSÓRIOS',
			if(match(AUX, 'PP') or match(BSART, 'ZSKU'),
				'PUSH & PULL',
				TMP_ORIGEM))) as ORIGEM,
	if(match(BSART, 'ZMD'),
		'Ressuprimento acessórios',
        if(match(BSART, 'ZFT'),
        	'Primeiro envio')) as TIPO_ENVIO_ACESSORIOS
Resident TMP_FATO;
drop table TMP_FATO;

drop field AUX;

