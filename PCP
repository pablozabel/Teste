    CDDEST as CD_ABASTECEDOR
from [$(vGlobalDirDadoExtraidoSAPECC)/ZWMUCT007.qvd] (qvd)
where trim(CDDEST) <> '';

Map_Remessa:
mapping Load
    VGBEL as EBELN,
    VBELN
FROM [lib://CNNDIR-Dados/Extraídos/SAP ECC/LOG-LEADTIME/LIPS.qvd] (qvd)
Where Exists(DAT_CALENDARIO_CIVIL,ERDAT) and len(trim(VGBEL)) >0;

MapArvore:
