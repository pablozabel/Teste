tmp_qtd_embarcado:
Load
	[Número da requisição]&'|'&%MATERIAL_CHAVE as [%CHAVE_REQUISICAO],
    sum(QTD_EMBARCADO) as QTD_TOTAL_EMBARCADO
resident TMP_FATO
where TIPO = 'EMBARCADO'
group by
	[Número da requisição],
    %MATERIAL_CHAVE;
    
Map_qtd_embarcado:
mapping load
	[%CHAVE_REQUISICAO],
    QTD_TOTAL_EMBARCADO
resident tmp_qtd_embarcado;

drop table tmp_qtd_embarcado;

