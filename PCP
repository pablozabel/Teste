À EMBARCAR CROSS
**************************/


Concatenate (TMP_FATO)
Load 
	EXIDV,
	VBELN as [Número da remessa],
	EBELN as [Número do Pedido],
    VBELN as [Filtro_Remessa_Cross_embarcar],
    %MATERIAL_CHAVE,
    [CD ORIGEM],
    QTD,
    QTD as QTD_FINALIZADO,
    [CD SECUNDARIO],
	[CD HUB],
    alt(ApplyMap('MapDatFimPedido', VBELN, null()),DAT_CRIACAO_REMESSA) as DAT_FINALIZADO,
    alt(ApplyMap('MapDatFimPedido', VBELN, null()),DAT_CRIACAO_REMESSA) as %DATA_CHAVE,
    %CENTRO_CHAVE_CROSS,
    'À EMBARCAR' as TIPO,
    'CROSS' as TMP_ORIGEM
resident ZWMUCT006
where 
(
    (
        ([CD ORIGEM] = '1075' 
         and ([CD SECUNDARIO]='1156' or [CD HUB] = '1117'))
        or exists([Remessa_Cross_embarcar], VBELN)
        or match([CD ORIGEM], '1156','1117')
    )
    and 
    not Exists([Remessa Finalizada], VBELN)
    and trim(VBELN) <> ''
);
