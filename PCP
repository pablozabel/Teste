[CALENDÁRIO PRODUÇÃO]:
LOAD Distinct
	DAT_CALENDARIO_CIVIL 																as DAT_FINALIZADO,
    DAT_CALENDARIO_CIVIL								                                AS [Produção Data],
    date(DAT_CALENDARIO_CIVIL,'DD/MMM')                  								AS [Produção Data de Referência Resumida],
    day(DAT_CALENDARIO_CIVIL)                                                           AS [Produção Dia do Mês],
    TIPO															                    AS [Produção Tipo_Data],
    NUM_DIA_SEMANA                                                                      AS [Produção Dia da Semana],   
    NUM_SEMANA		                                                                    AS [Produção Número da Semana],
    Dual(NUM_SEMANA&'/'&Year(DAT_CALENDARIO),
         Num(Year(DAT_CALENDARIO)&NUM_SEMANA))                                          AS [Produção Semana/Ano],
    DAT_CALENDARIO 											                            AS [Produção %Data Comercial],
    Year(DAT_CALENDARIO)&' - '&NUM_SEMANA&' - '&NUM_DIA_SEMANA                          AS [Produção Ano Semana Dia],
    Year([DAT_CALENDARIO_CIVIL])                      				                    AS [Produção Ano Civil],
    Year([DAT_CALENDARIO])					    				                	    AS [Produção Ano Comercial],
    Month([DAT_CALENDARIO_CIVIL])			            			                    AS [Produção Mês Civil],
    Month([DAT_CALENDARIO])					        				                    AS [Produção Mês Comercial],
    Date([DAT_CALENDARIO_CIVIL],'MM/YYYY')							                    AS [Produção Mês Ano Civil],
    Date([DAT_CALENDARIO],'MM/YYYY')								                    AS [Produção Mês Ano Comercial]
////MM002 - Fim  
FROM [$(vGlobalDirDadoTransformado)/Dim_Calendario_Comercial_Asof_Cubo.qvd] (qvd)
Where DAT_CALENDARIO_CIVIL >= AddMonths(Today(),-2) and DAT_CALENDARIO_CIVIL <= AddMonths(Today(),1) and TIPO = 'Dia Ano Atual';

